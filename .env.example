# Copy to `.env.local` for dev, or set in Vercel project env for prod.
# Everything here is optional — if unset, the corresponding feature is simply inert.

# ── Analytics ──────────────────────────────────────────────────────────────
# Google Analytics 4 measurement ID. Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA4_ID=

# PostHog project API key (public, safe to expose). Starts with phc_
NEXT_PUBLIC_POSTHOG_KEY=
# PostHog host. EU: https://eu.i.posthog.com  — US: https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ── Search engine verification (meta tags) ─────────────────────────────────
# Google Search Console — the content value of the google-site-verification tag
NEXT_PUBLIC_GSC_VERIFICATION=
# Bing Webmaster Tools — the content value of the msvalidate.01 tag
NEXT_PUBLIC_BING_VERIFICATION=

# ── IndexNow (fast-ping Bing/Yandex/Seznam on deploy) ──────────────────────
# 32-char hex key. Generate with: openssl rand -hex 16
# The same value must be served at /{key}.txt (route handled automatically).
INDEXNOW_KEY=

# ── Notion waitlist (email capture for the Android beta) ───────────────────
# Internal integration secret from https://www.notion.so/profile/integrations
# The integration must be added to the Waitlist DB via ⋯ → Connections.
# Until this is set, /api/waitlist still returns success and logs the
# signup to the Vercel function console.
NOTION_API_TOKEN=
# (Optional) override the default database id if the Waitlist DB moves.
NOTION_WAITLIST_DB_ID=
